# Coach-bot — copy to .env and fill in your values
# Or run ./setup.sh for an interactive wizard.

# ── LLM backend ──────────────────────────────────────────────
# Pick ONE backend and enable it. All are disabled by default.

# Google Gemini — free key at aistudio.google.com/app/apikey
# BOT_LLM_GEMINI_ENABLED=true
# GEMINI_API_KEY=AIza...
# BOT_DEFAULT_LLM_BACKEND=gemini

# Anthropic Claude
# BOT_LLM_CLAUDE_ENABLED=true
# ANTHROPIC_API_KEY=sk-ant-api03-...
# BOT_DEFAULT_LLM_BACKEND=claude

# OpenAI / OpenRouter / any OpenAI-compatible endpoint
# BOT_LLM_OPENAI_ENABLED=true
# OPENAI_API_KEY=sk-...
# BOT_LLM_OPENAI_MODEL=gpt-4o
# BOT_LLM_OPENAI_BASE_URL=https://openrouter.ai/api/v1   # optional
# BOT_DEFAULT_LLM_BACKEND=openai

# Local Ollama (no key needed)
# BOT_LLM_OLLAMA_ENABLED=true
# BOT_LLM_OLLAMA_BASE_URL=http://host.docker.internal:11434
# BOT_LLM_OLLAMA_MODEL=gemma3:12b
# BOT_LLM_OLLAMA_TIMEOUT_SECONDS=300
# BOT_DEFAULT_LLM_BACKEND=ollama

# ── Transports ────────────────────────────────────────────────
BOT_TRANSPORTS_CONSOLE_ENABLED=true
BOT_TRANSPORTS_TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=123456789:AAF...

# Jabber / XMPP (optional)
# BOT_TRANSPORTS_JABBER_ENABLED=true
# BOT_JABBER_SERVER=jabber.org
# BOT_JABBER_USERNAME=bot@jabber.org
# BOT_JABBER_PASSWORD=secret

# ── Agent ─────────────────────────────────────────────────────
BOT_AGENT_NAME="My Coach"

# ── Admin UI ──────────────────────────────────────────────────
BOT_WEB_USERNAME=admin
BOT_WEB_PASSWORD=coach-bot        # change this in production!
BOT_WEB_PORT=8080

# ── Language / timezone / translation ─────────────────────────
BOT_TIMEZONE=UTC                  # IANA timezone, e.g. Europe/London, America/New_York
BOT_LANGUAGE=en                   # ISO 639-1: ru, de, es, fr, … (en = no translation)
# BOT_TRANSLATE_API_KEY=you@example.com   # raises MyMemory limit to 10k chars/day

# ── Storage ───────────────────────────────────────────────────
BOT_STORAGE_OBSIDIAN_ENABLED=false
# OBSIDIAN_VAULT_PATH=/absolute/path/to/your/ObsidianVault
